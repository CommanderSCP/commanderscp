{
  "name": "commanderscp",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=22.11 <23"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration",
    "openapi:emit": "pnpm --filter @scp/server openapi:emit",
    "sdk:generate": "pnpm --filter @scp/sdk generate",
    "gen": "pnpm run openapi:emit && pnpm run sdk:generate",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run gen && git diff --exit-code",
    "doctor": "node scripts/doctor.mjs",
    "seed": "pnpm --filter @scp/server seed",
    "changeset": "changeset"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@eslint/js": "^9.9.0",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.9.0",
    "prettier": "^3.3.0",
    "tsx": "^4.19.0",
    "turbo": "^2.1.0",
    "typescript": "~5.8.0",
    "typescript-eslint": "^8.5.0",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2",
      "cpu-features",
      "esbuild",
      "protobufjs",
      "ssh2"
    ]
  }
}
