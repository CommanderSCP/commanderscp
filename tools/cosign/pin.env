# Single source of truth for the vendored cosign pin (M17.3 E1).
#
# Shell-sourceable (`. tools/cosign/pin.env`) AND parsed verbatim by:
#   - Dockerfile                              (ARG COSIGN_IMAGE default — must match COSIGN_PINNED_IMAGE)
#   - scripts/install-pinned-cosign.sh        (CI installs THIS binary, not a network installer)
#   - deploy/airgap/src/cosign-bin.ts         (runtime resolution + fail-closed version assertion)
#   - scripts/doctor.mjs                      (reports the pin)
# `deploy/airgap/src/cosign-bin.test.ts` asserts all of those agree with this file — see
# tools/cosign/README.md ("Updating the pin") before changing anything here.

# cosign release this pin corresponds to (matches `cosign version`'s GitVersion output).
COSIGN_PINNED_VERSION=v3.1.2

# The linux/amd64 PLATFORM manifest digest — deliberately NOT the multi-arch index digest, so the
# ref resolves to exactly one architecture no matter what the build host is (see README.md
# "Why the platform digest, not the index digest").
COSIGN_PINNED_IMAGE=ghcr.io/sigstore/cosign/cosign@sha256:bea051df6a6d3bc84288b6db098df38a81d87b7ed226f34d22aaae1bc329c2b7

# The multi-arch index digest for v3.1.2, recorded for provenance only (nothing consumes it).
COSIGN_PINNED_INDEX_DIGEST=sha256:d91bc4e7e95e8d2f549c747a72dc174f90579e410a1695f57f686674f84ce849

# Path of the cosign binary INSIDE the upstream (ko-built, distroless) cosign image.
COSIGN_UPSTREAM_PATH=/ko-app/cosign

# Where the SCP runtime image puts it. Deliberately NOT /usr/local/bin — see README.md
# ("Why /opt/scp/bin, not /usr/local/bin").
COSIGN_VENDORED_PATH=/opt/scp/bin/cosign
