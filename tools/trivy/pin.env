# Single source of truth for the vendored Trivy pin (M13.3a — the `scp-runner-scan` image).
#
# Shell-sourceable (`. tools/trivy/pin.env`) AND parsed verbatim by:
#   - apps/runner-scan/Dockerfile   (ARG TRIVY_IMAGE default — must match TRIVY_PINNED_IMAGE)
# `packages/plugins/managed-scan/src/pin.test.ts` asserts the Dockerfile agrees with this file —
# see tools/trivy/README.md ("Updating the pin") before changing anything here.
#
# WHY THE INDEX DIGEST, NOT THE amd64 PLATFORM DIGEST, FOR THE `FROM` (the deliberate deviation from
# tools/cosign/pin.env and tools/skopeo/pin.env): cosign and skopeo are vendored BINARIES — copied
# OUT of an image that is never executed, so those pins force the exact linux/amd64 platform digest.
# `scp-runner-scan` is different: the image is EXECUTED as an ephemeral runner (like scp-runner-iac,
# which `FROM`s a multi-arch OpenTofu TAG for the same reason). Pinning the multi-arch INDEX digest
# keeps the pull content-addressed and reproducible while resolving to the BUILD HOST's architecture,
# so the runner runs natively (amd64 in production, arm64 on an arm dev/CI host) with no emulation.
# The linux/amd64 platform digest — the production runner target arch — is recorded below for
# provenance and asserted by the drift test.

# Trivy release this pin corresponds to (matches `trivy version`'s Version output).
TRIVY_PINNED_VERSION=0.58.1

# The trivy-db SCHEMA VERSION the pinned binary above can read (M13.3b-ii). trivy-db's on-disk
# `metadata.json` carries a `Version` integer; a DB built for a DIFFERENT schema version than the
# binary expects is UNREADABLE — so the offline pre-load + refresh path (governance/scan-db.ts)
# ASSERTS a candidate DB's schema equals this before accepting it into the cache (fail-closed refuse
# of a DB the pinned Trivy can't read). Trivy 0.58.x uses trivy-db schema v2. Mirrored in
# `packages/schemas`/`governance/scan-db.ts` (EXPECTED_TRIVY_DB_SCHEMA_VERSION) and asserted by the
# scan-db unit test against this file, exactly as the image pins are drift-tested against pin.test.ts.
TRIVY_DB_SCHEMA_VERSION=2

# The upstream repository (docker.io/aquasec/trivy). Recorded so the drift test can assert the
# Dockerfile FROM names exactly this repo at exactly the pinned digest.
TRIVY_UPSTREAM_REPO=aquasec/trivy

# The multi-arch INDEX (manifest-list) digest — consumed by apps/runner-scan/Dockerfile's `FROM`.
# Resolves per build-host arch; content-addressed and reproducible.
TRIVY_PINNED_IMAGE=aquasec/trivy@sha256:ab70a02200597efa04748f210f793936eb647cbcdb0ea69cc30b226d6f5a22c7

# The linux/amd64 PLATFORM manifest digest for v0.58.1 (the production runner target arch) —
# recorded for provenance and asserted by the drift test; nothing consumes it at build time.
TRIVY_PINNED_AMD64_DIGEST=sha256:de81be41be9665a7b761680cd4bb570313a923154b994c79b49b5a55f1a55e35
