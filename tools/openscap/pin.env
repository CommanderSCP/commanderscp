# Single source of truth for the vendored OpenSCAP pin (M13.3b part 1 — the second managed-scan
# method in the `scp-runner-scan` image). Mirrors tools/trivy/pin.env in shape.
#
# Shell-sourceable (`. tools/openscap/pin.env`) AND parsed verbatim by:
#   - apps/runner-scan/Dockerfile   (ARG OPENSCAP_IMAGE default — must match OPENSCAP_PINNED_IMAGE)
# `packages/plugins/managed-scan/src/pin.test.ts` asserts the Dockerfile agrees with this file — see
# tools/openscap/README.md ("Updating the pin") before changing anything here.
#
# WHAT THIS PINS, AND WHY A FEDORA IMAGE. Unlike cosign/skopeo/trivy (vendored BINARIES copied out of
# an image that is never executed), `oscap` needs its OVAL/SCE probe binaries AND the SCAP Security
# Guide (SSG) datastream content present and glibc-linked — building it FROM Alpine (Trivy's base) is
# an ldd nightmare. So the `scp-runner-scan` FINAL base is a digest-pinned Fedora image that carries
# `oscap` (openscap-scanner) + the SSG datastreams (scap-security-guide), installed at BUILD time; the
# Trivy binary + baked DB are COPY'd IN from the pinned Trivy stage (tools/trivy/pin.env). Like
# scp-runner-iac (which FROMs a multi-arch OpenTofu image), this image is EXECUTED as an ephemeral
# runner, so the FROM pins the multi-arch INDEX digest (resolves per build-host arch); the linux/amd64
# platform digest — the production runner target arch — is recorded below and asserted by the drift test.
#
# HONEST LIMITATION (13.3b PART 1): the FEDORA IMAGE is digest-pinned, but `oscap` + SSG are
# `dnf install`ed from that base's DEFAULT repos at build time, so the exact PACKAGE versions track
# those repos rather than a content-addressed pin. OPENSCAP_PINNED_VERSION below records the oscap
# version the base's repos serve as of this pin (asserted only for FORMAT by the drift test — the
# Dockerfile asserts `oscap --version` SUCCEEDS at build, failing loudly if the toolchain is broken;
# it does not assert an exact version, which would break the build on every upstream repo refresh).
# Fully offline package vendoring / exact-version pinning + the SCAP-content `type: "blob"` transport
# is 13.3b PART 2 — deliberately out of scope for this increment, which keeps the build-time bake.

# The oscap release this pin corresponds to (matches `oscap --version`'s reported version at build).
OPENSCAP_PINNED_VERSION=1.4.2

# The upstream repository (docker.io/library/fedora). Recorded so the drift test can assert the
# Dockerfile FROM names exactly this repo at exactly the pinned digest.
OPENSCAP_UPSTREAM_REPO=fedora

# The multi-arch INDEX (manifest-list) digest — consumed by apps/runner-scan/Dockerfile's FINAL FROM.
# Resolves per build-host arch; content-addressed and reproducible. (Fedora 41.)
OPENSCAP_PINNED_IMAGE=fedora@sha256:f1a3fab47bcb3c3ddf3135d5ee7ba8b7b25f2e809a47440936212a3a50957f3d

# The linux/amd64 PLATFORM manifest digest for this Fedora index (the production runner target arch) —
# recorded for provenance and asserted by the drift test; nothing consumes it at build time.
OPENSCAP_PINNED_AMD64_DIGEST=sha256:68bb1ba893be0c05991b2df55bc6571862bab7526fd6053b1ebacd53a2a75366

# Where the SSG datastreams land inside the runner image (scap-security-guide). run.sh's `openscap`
# arm evaluates a datastream from this directory (default ssg-fedora-ds.xml; the promotion scan step
# selects a per-artifact datastream+profile). Recorded for documentation; nothing parses it.
OPENSCAP_SSG_CONTENT_DIR=/usr/share/xml/scap/ssg/content
