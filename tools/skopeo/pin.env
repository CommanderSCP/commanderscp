# Single source of truth for the vendored skopeo pin (M15.5 c1).
#
# Shell-sourceable (`. tools/skopeo/pin.env`) AND parsed verbatim by:
#   - Dockerfile                              (ARG SKOPEO_IMAGE default — must match SKOPEO_PINNED_IMAGE)
#   - packages/cosign/src/skopeo-bin.ts       (runtime resolution + fail-closed version assertion)
#   - scripts/install-pinned-skopeo.sh        (CI installs THIS binary+closure, not apt's skopeo)
# `deploy/airgap/src/skopeo-bin.test.ts` asserts all of those agree with this file — see
# tools/skopeo/README.md ("Updating the pin") before changing anything here.

# skopeo release this pin corresponds to (matches the version `skopeo --version` reports; note
# upstream reports it WITHOUT a leading `v`, unlike cosign).
SKOPEO_PINNED_VERSION=1.22.2

# The linux/amd64 PLATFORM manifest digest — deliberately NOT the multi-arch index digest, so the
# ref resolves to exactly one architecture no matter what the build host is (see README.md
# "Why the platform digest, not the index digest").
SKOPEO_PINNED_IMAGE=quay.io/skopeo/stable@sha256:8b23fe434af822adf71bc7c8674a8dfab379771aa1400fb81ff655a5cecfca87

# The multi-arch index digest for tag v1.22.2, recorded for provenance only (nothing consumes it).
SKOPEO_PINNED_INDEX_DIGEST=sha256:c7d3c512612f52805023cd38351081dad7e2729fc13d14b701e47c7c8bdd6615

# Path of the skopeo binary INSIDE the upstream (Fedora-based) skopeo image.
SKOPEO_UPSTREAM_PATH=/usr/bin/skopeo

# The entry point inside the SCP runtime image — a wrapper script (tools/skopeo/skopeo-wrapper.sh)
# that runs the vendored binary against its OWN vendored loader + library closure (the upstream
# binary is dynamically linked, unlike cosign's static one — see README.md "The dynamic-linking
# deviation"). Deliberately NOT /usr/local/bin, same as cosign: an operator-installed skopeo must
# never be mistaken for the vetted pin.
SKOPEO_VENDORED_PATH=/opt/scp/bin/skopeo

# Where the real ELF binary + its library closure live inside the SCP runtime image.
SKOPEO_LIBEXEC_DIR=/opt/scp/libexec/skopeo
