{
  "name": "@scp/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -b",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "test:integration": "vitest run --config vitest.integration.config.ts --passWithNoTests",
    "openapi:emit": "tsx src/openapi-emit.ts",
    "db:generate": "drizzle-kit generate",
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.0",
    "@fastify/static": "^8.0.0",
    "@scp/schemas": "workspace:*",
    "@scp/sdk": "workspace:*",
    "ajv": "^8.17.0",
    "argon2": "^0.41.0",
    "cel-js": "^0.3.0",
    "drizzle-orm": "^0.36.0",
    "fastify": "^5.5.0",
    "fastify-type-provider-zod": "^7.0.0",
    "openid-client": "^6.1.0",
    "pg": "^8.13.0",
    "pg-boss": "^10.1.0",
    "pino": "^9.5.0",
    "uuid": "^11.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^10.14.0",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.28.0",
    "fast-check": "^3.23.0",
    "nock": "^13.5.0",
    "testcontainers": "^10.14.0",
    "tsx": "^4.19.0",
    "typescript": "~5.8.0",
    "vitest": "^3.0.0"
  }
}
